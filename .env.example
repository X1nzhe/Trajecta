# Trajecta environment template
# Copy to .env at the repo root (do not commit .env):
#   cp .env.example .env
#
# Shell exports take precedence over .env (python-dotenv override=False).
# Without OPENAI_API_KEY + model vars, the backend uses OfflineAgentMock and MockVLMClient.

# =============================================================================
# OpenAI — real Eval Agent + VLM + optional RAG embeddings
# =============================================================================
# Required together for the tool-calling Eval Agent (else OfflineAgentMock).
# OPENAI_API_KEY=sk-your-openai-key
# TRAJECTA_AGENT_MODEL=gpt-4o-mini

# Required together for trajectory preprocessing + get_step_detail VLM (else MockVLMClient).
# TRAJECTA_VLM_MODEL=gpt-4o-mini

# Optional: OpenAI-compatible API base URL (also used as Judge B fallback).
# OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# Prompt versions (committed under prompts/)
# =============================================================================
# Eval Agent bundle; default in code: v1_minimal
# TRAJECTA_PROMPT_VERSION=v1_minimal

# High-detail VLM bundle; default in code: v1_task_context
# TRAJECTA_VLM_HIGH_DETAIL_PROMPT_VERSION=v1_task_context

# Spotlighting defense for untrusted trajectory text; default: on
# TRAJECTA_SPOTLIGHTING=on

# =============================================================================
# Data paths and ChromaDB
# =============================================================================
# SQLite + fixtures root; default: <repo>/data
# TRAJECTA_DATA_DIR=

# Chroma persistence; default: <TRAJECTA_DATA_DIR>/chroma
# TRAJECTA_CHROMA_DIR=

# Embedding model for failure-memory RAG. Changing it requires clearing/rebuilding chroma.
# TRAJECTA_EMBEDDING_MODEL=text-embedding-3-small

# Deterministic fake embeddings (pytest sets this). Do not use in production.
# TRAJECTA_USE_FAKE_EMBEDDING=1

# =============================================================================
# Phase 8 dual LLM judge (python -m eval.judge / agent_eval --judge)
# =============================================================================
# Each slot needs MODEL + PROMPT_VERSION. Model IDs are not hard-coded in the repo.

# Judge A — Gemini-compatible OpenAI API (does NOT fall back to OPENAI_API_KEY).
# TRAJECTA_JUDGE_A_MODEL=gemini-2.0-flash
# TRAJECTA_JUDGE_A_PROMPT_VERSION=v1_acceptability_gemini
# TRAJECTA_JUDGE_A_API_KEY=your-gemini-or-proxy-key
# TRAJECTA_JUDGE_A_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Judge B — OpenAI-compatible (API key / base URL fall back to OPENAI_* when unset).
# TRAJECTA_JUDGE_B_MODEL=gpt-4o-mini
# TRAJECTA_JUDGE_B_PROMPT_VERSION=v1_acceptability_openai
# TRAJECTA_JUDGE_B_API_KEY=
# TRAJECTA_JUDGE_B_BASE_URL=

# =============================================================================
# Optional — experiments, CLI, dataset tooling
# =============================================================================
# Redact sensitive fields from tool payloads (agent_eval sets 1 by default).
# TRAJECTA_EVAL_MODE=1

# Hugging Face token for scripts/materialize_molmoweb_sample.py
# HF_TOKEN=hf_your-token

# Opt-in RAG integration test only (backend/tests/test_rag.py).
# TRAJECTA_RAG_INTEGRATION=1
